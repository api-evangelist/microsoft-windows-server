  "name": "Certificate",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "issued_by": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "thumbprint": {
